window-width = 300
window-height = 60
font-family = "Source Code Pro Medium"
font-size = 10
# font line height
adjust-cell-height = 5

window-save-state=always
unfocused-split-opacity = 1

# keybinds

keybind = ctrl+,=unbind
keybind = ctrl+shift+r=reload_config

keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right


keybind = performable:super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = ctrl+t=new_tab

# tabs navigation
keybind = ctrl+shift+h=previous_tab
keybind = ctrl+shift+l=next_tab


# splits
keybind = ctrl+shift+o=new_split:right
keybind = ctrl+shift+m=new_split:down
keybind = ctrl+shift+x=close_surface

# resize splits
keybind = ctrl+alt+h=resize_split:left,20
keybind = ctrl+alt+j=resize_split:down,20
keybind = ctrl+alt+k=resize_split:up,20
keybind = ctrl+alt+l=resize_split:right,20

# padding
window-padding-balance = true
window-padding-x = 0
window-padding-y = 0
window-padding-color = extend

config-file = ?config.local




